# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is already in .gitignore.

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" header used for both emails.
# Must be on a domain verified in Resend.
DEMO_FROM=Enerflo.ai <hello@enerflo-ai.co.uk>

# Inbox that receives the notification email for every demo request.
# Point this at hello@enerflo-ai.co.uk (forwarded to Gmail via ImprovMX / Cloudflare).
DEMO_NOTIFY_TO=hello@enerflo-ai.co.uk

# Reply-To header used on the auto-reply sent to the submitter.
DEMO_REPLY_TO=support@enerflo-ai.co.uk
